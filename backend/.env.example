PORT=4000
# Supabase Project Settings > Database > Connection string
# (data-pipeline/.env의 SUPABASE_DB_URL과 동일한 값을 쓰면 됩니다)
DATABASE_URL=

# 프론트 개발 서버 주소 (Vite 기본값). 여러 origin을 허용하려면 콤마로 구분.
FRONTEND_ORIGIN=http://localhost:5173

# POST /cities/:cityId/update가 main_batch.py를 자식 프로세스로 실행할 때 쓰는 설정.
# PYTHON_BIN: data-pipeline 의존성(playwright, psycopg2 등)이 설치된 python 실행 파일.
# DATA_PIPELINE_DIR: 비워두면 backend와 나란히 있는 ../data-pipeline을 기본값으로 쓴다.
PYTHON_BIN=python3
DATA_PIPELINE_DIR=
